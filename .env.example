# Public hostname. DNS must point to your home connection.
BARLEY_DOMAIN=barley.boily.me

# External drive recordings directory on the barley-vision Raspberry Pi.
HOST_RECORDINGS_DIR=/media/yboily/New Volume/recordings

# Used by Let's Encrypt account registration and expiry notifications.
LETSENCRYPT_EMAIL=yvanboily+barley@gmail.com

# Generate with:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext 'replace-me'
CADDY_YBOILY_PASSWORD_HASH=REPLACE_WITH_CADDY_HASH

# SMTP settings for msmtp.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=on
SMTP_STARTTLS=on
SMTP_USER=yvanboily+barley@gmail.com
SMTP_PASSWORD=replace-me
SMTP_FROM=yvanboily+barley@gmail.com
SMTP_TO=yvanboily+barley@gmail.com

# Recording retention.
MAX_RECORDING_BYTES=34359738368
MIN_RECORDING_AGE_HOURS=24
